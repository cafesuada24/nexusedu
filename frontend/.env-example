# ==========================================
# Frontend Environment Configuration Example
# ==========================================
# Copy this file to .env or .env.local and update the values as needed.

# --- Environment ---
# Sets the running environment (development, production, etc.)
NODE_ENV="development"

# --- API & Backend Connections ---
# The base URL for the backend API.
# In development, this points to the local backend server.
NEXT_PUBLIC_API_BASE_URL="http://localhost:8000/api/v1"

# The WebSocket URL for real-time updates.
# If omitted, the frontend will attempt to infer it from NEXT_PUBLIC_API_BASE_URL.
NEXT_PUBLIC_WS_URL="ws://localhost:8000/ws"

# --- Logging & Debugging ---
# Controls the verbosity of the frontend logger (debug, info, warn, error).
LOG_LEVEL="debug"

# Set to "1" to enable verbose logging in the Next.js API proxy middleware.
# Very useful for debugging token injection and request routing.
DEBUG_API_PROXY_LOGS="0"
