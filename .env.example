# Choose one or both providers
GOOGLE_API_KEY=...
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO

# Security
JWT_SECRET="YOUR_JWT_SECRET"

# POSTGRES
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=a20app
DATABASE_URL=postgresql+psycopg://myuser:mypassword@db:5432/a20app
DB_INGEST_CHUNK_SIZE=50

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=local_redis_pass_change_me

# CONFIG
WORKER_MAX_JOBS=5
WORKER_JOB_TIMEOUT_SEC=60
ALLOWED_ORIGINS='localhost:3000' # 'http://localhost:3000'

REVIEW_URL_TEMPLATE="http://localhost:3000/review?token={token}"

# SMTP (Mailgun/Mailpit)
SMTP_HOST=mailpit
SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_USE_TLS=False
SMTP_START_TLS=False

# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@yourdomain.com
# SMTP_PASSWORD=your_password
# SMTP_FROM_EMAIL=notifications@yourdomain.com
# SMTP_USE_TLS=False
# SMTP_START_TLS=True

# LOGGING & OBSERVABILITY
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_EXPORTER_OTLP_HEADERS: Where you put API keys (e.g., x-honeycomb-team=your-key).
# OTEL_EXPORTER_OTLP_PROTOCOL: Usually http/protobuf or grpc.

# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST="https://cloud.langfuse.com"

# LangSmith
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...

# AI Hook Logging (set by instructor)
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=lMfm8NPzHVHlOtYx2kOQ7c9PTxJOB0E3DJbD_UBlsFw
AI_LOG_DIR=.ai-log
