# Choose one or both providers
GOOGLE_API_KEY=...
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO

# Security
JWT_SECRET="YOUR_JWT_SECRET"

# POSTGRES
# PG_DSN=""
DATABASE_URL="sqlite+aiosqlite:///./data/app.db"
DB_INGEST_CHUNK_SIZE=50

# Redis
REDIS_HOST='localhost'
REDIS_PORT=6379

# CONFIG
WORKER_MAX_JOBS=5
WORKER_JOB_TIMEOUT_SEC=60
ALLOWED_ORIGINS='' # 'http://localhost:3000'

BOOKING_URL_TEMPLATE="http://localhost:3000/booking?cid={cid}"
REVIEW_URL_TEMPLATE="http://localhost:3000/review?token={token}"

# SMTP
SMTP_HOST=localhost
SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com

# LOGGING & OBSERVABILITY
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_HEADERS: Where you put API keys (e.g., x-honeycomb-team=your-key).
# OTEL_EXPORTER_OTLP_PROTOCOL: Usually http/protobuf or grpc.

# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST="https://cloud.langfuse.com"

# LangSmith
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...

# AI Hook Logging (set by instructor)
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=lMfm8NPzHVHlOtYx2kOQ7c9PTxJOB0E3DJbD_UBlsFw
AI_LOG_DIR=.ai-log
