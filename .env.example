# Choose one or both providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO

# Security
ALLOWED_ORIGINS=http://localhost:3000
JWT_SECRET="YOUR_JWT_SECRET"

# POSTGRES
# PG_DSN=""
DATABASE_URL="sqlite+aiosqlite:///./data/app.db"
DB_INGEST_CHUNK_SIZE=50

# Redis
REDIS_HOST='localhost'
REDIS_PORT=6379

# CONFIG
WORKER_MAX_JOBS=5
WORKER_JOB_TIMEOUT_SEC=60
ALLOWED_ORIGINS='' # 'http://localhost:3000'

BOOKING_URL_TEMPLATE="http://localhost:3000/booking/advisor?cid={cid}"
REVIEW_URL_TEMPLATE="http://localhost:3000/review?token={token}"

# MotherDuck (Optional: Fallback to local DuckDB if missing)
MOTHERDUCK_TOKEN=

# SMTP
SMTP_HOST=localhost
SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com

# AI Hook Logging (set by instructor)
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=lMfm8NPzHVHlOtYx2kOQ7c9PTxJOB0E3DJbD_UBlsFw
AI_LOG_DIR=.ai-log
